---
import Base from '../../layouts/Base.astro';
---

<Base title="Create Blog - Open English Translation">
    <div style={{ display: 'flex', width: '100%', minHeight: '100vh' }}>
        <div style={{ flex: '1', padding: '1rem' }}>
            <input
                id="title-input"
                type="text"
                placeholder="Title"
                style={{ display: 'block', width: '100%', marginBottom: '0.5rem', padding: '0.5rem' }}
            />
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'center', marginBottom: '0.5rem', gap: '0.5rem' }}>
                <label for="published-select">Publish</label>
                <select id="published-select" style={{ padding: '0.5rem' }}>
                    <option value="false">False</option>
                    <option value="true">True</option>
                </select>
            </div>
            <input
                id="author-input"
                type="text"
                placeholder="Author"
                style={{ display: 'block', width: '100%', marginBottom: '0.5rem', padding: '0.5rem' }}
            />
            <input
                id="label-input"
                placeholder="Enter a label"
                style={{ display: 'block', width: '100%', marginBottom: '0.5rem', padding: '0.5rem' }}
            />
            <div id="labels-container" style={{ display: 'flex', flexWrap: 'wrap', gap: '0.5rem', marginBottom: '0.5rem' }}></div>
            <div id="image-preview" style={{ minHeight: '30px', display: 'flex', gap: '0.5rem', flexWrap: 'wrap', marginBottom: '0.5rem' }}></div>
            <input
                type="file"
                id="file-input"
                name="ImageStyle"
                style={{ display: 'block', marginBottom: '0.5rem' }}
            />
            <textarea
                id="editor"
                style={{ width: '100%', minHeight: '300px', padding: '0.5rem', fontFamily: 'monospace' }}
            ></textarea>
            <div style={{ marginTop: '0.5rem', marginBottom: '0.5rem' }}>
                <label for="auth-username">Basic Auth </label>
                <input id="auth-username" placeholder="username" type="text" style={{ padding: '0.5rem', marginRight: '0.5rem' }} />
                <input id="auth-password" placeholder="password" type="password" style={{ padding: '0.5rem' }} />
            </div>
            <div style={{ display: 'flex', justifyContent: 'space-evenly', marginBottom: '0.5rem' }}>
                <button id="submit-btn" style={{ padding: '0.5rem 1rem', cursor: 'pointer' }}>Submit</button>
                <button id="clear-btn" style={{ padding: '0.5rem 1rem', cursor: 'pointer' }}>clear</button>
            </div>
            <div id="response-output" style={{ gridColumn: '1/3' }}></div>
        </div>
        <div style={{ flex: '1', padding: '1rem' }}>
            <h1 id="preview-title"></h1>
            <div id="preview-body"></div>
            <span id="preview-author"></span>
            <ul id="preview-labels"></ul>
            <div id="preview-dates"></div>
        </div>
    </div>
</Base>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
        var titleInput = document.getElementById('title-input');
        var publishedSelect = document.getElementById('published-select');
        var authorInput = document.getElementById('author-input');
        var labelInput = document.getElementById('label-input');
        var labelsContainer = document.getElementById('labels-container');
        var fileInput = document.getElementById('file-input');
        var imagePreview = document.getElementById('image-preview');
        var submitBtn = document.getElementById('submit-btn');
        var clearBtn = document.getElementById('clear-btn');
        var responseOutput = document.getElementById('response-output');
        var previewTitle = document.getElementById('preview-title');
        var previewBody = document.getElementById('preview-body');
        var previewAuthor = document.getElementById('preview-author');
        var previewLabels = document.getElementById('preview-labels');
        var previewDates = document.getElementById('preview-dates');

        var labels = JSON.parse(localStorage.getItem('labels') || '[]');
        var images = [];

        var now = new Date();
        var dateStr = now.getDate() + '/' + (now.getMonth() + 1) + '/' + now.getFullYear();

        titleInput.value = localStorage.getItem('title') || '';
        publishedSelect.value = localStorage.getItem('published') || 'false';
        authorInput.value = localStorage.getItem('author') || '';

        var editorTextarea = document.getElementById('editor');
        editorTextarea.value = localStorage.getItem('body') || '';

        var easyMDE = new EasyMDE({
            element: editorTextarea,
            spellChecker: false,
            toolbar: ['bold', 'italic', 'heading', '|', 'quote', 'code'],
            initialValue: localStorage.getItem('body') || '',
        });

        function persist(key, value) {
            localStorage.setItem(key, value);
        }

        function renderLabels() {
            labelsContainer.innerHTML = '';
            labels.forEach(function (tag, index) {
                var el = document.createElement('div');
                el.textContent = tag;
                el.style.cursor = 'pointer';
                el.style.padding = '0.25rem 0.5rem';
                el.style.background = '#e0e0e0';
                el.style.borderRadius = '4px';
                el.addEventListener('click', function () {
                    labels.splice(index, 1);
                    persist('labels', JSON.stringify(labels));
                    renderLabels();
                    updatePreview();
                });
                labelsContainer.appendChild(el);
            });
        }

        function updatePreview() {
            previewTitle.textContent = titleInput.value;
            if (typeof marked !== 'undefined' && easyMDE.value()) {
                previewBody.innerHTML = marked.parse(easyMDE.value());
            } else {
                previewBody.textContent = '';
            }
            previewAuthor.textContent = authorInput.value ? 'Author is ' + authorInput.value : '';
            previewLabels.innerHTML = '';
            labels.forEach(function (label) {
                var li = document.createElement('li');
                li.textContent = label;
                previewLabels.appendChild(li);
            });
            if (easyMDE.value()) {
                previewDates.innerHTML = '<span>created on ' + dateStr + '</span><br/><span>last edited on ' + dateStr + '</span>';
            } else {
                previewDates.innerHTML = '';
            }
        }

        titleInput.addEventListener('input', function () {
            persist('title', titleInput.value);
            updatePreview();
        });

        publishedSelect.addEventListener('change', function () {
            persist('published', publishedSelect.value);
        });

        authorInput.addEventListener('input', function () {
            persist('author', authorInput.value);
            updatePreview();
        });

        easyMDE.codemirror.on('change', function () {
            persist('body', easyMDE.value());
            updatePreview();
        });

        labelInput.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') {
                var trimmed = labelInput.value.trim();
                if (trimmed.length && labels.indexOf(trimmed) === -1) {
                    e.preventDefault();
                    labels.push(trimmed);
                    persist('labels', JSON.stringify(labels));
                    labelInput.value = '';
                    renderLabels();
                    updatePreview();
                }
            }
        });

        fileInput.addEventListener('change', function (event) {
            if (event.target.files && event.target.files[0]) {
                var img = event.target.files[0];
                var src = URL.createObjectURL(img);
                images.push({ name: img.name, file: img, src: src });

                var imgEl = document.createElement('img');
                imgEl.src = src;
                imgEl.alt = img.name;
                imgEl.width = 50;
                imgEl.style.cursor = 'pointer';
                imgEl.addEventListener('click', function () {
                    navigator.clipboard.writeText(
                        '<img src="' + src + '" alt=\'' + img.name + '\' width="50" height="50" />'
                    );
                });
                imagePreview.appendChild(imgEl);
            }
        });

        submitBtn.addEventListener('click', async function () {
            var formData = new FormData();
            formData.append('title', titleInput.value);
            formData.append('published', publishedSelect.value);
            formData.append('body', easyMDE.value());
            formData.append('author', authorInput.value);
            formData.append('labels', labels.toString());

            images.forEach(function (img) {
                formData.append('image', img.file, img.name);
            });

            var username = document.getElementById('auth-username').value;
            var password = document.getElementById('auth-password').value;

            try {
                var apiUrl = (typeof import.meta !== 'undefined' && import.meta.env && import.meta.env.PUBLIC_API_URL)
                    ? import.meta.env.PUBLIC_API_URL
                    : '';
                var resp = await fetch(apiUrl + '/api/blogs/', {
                    method: 'POST',
                    headers: {
                        'Authorization': 'Basic ' + btoa(username + ':' + password),
                    },
                    body: formData,
                });
                var data = await resp.json();
                responseOutput.textContent = JSON.stringify(data);
            } catch (err) {
                responseOutput.textContent = JSON.stringify(err.message || err);
            }
        });

        clearBtn.addEventListener('click', function () {
            titleInput.value = '';
            authorInput.value = '';
            publishedSelect.value = 'false';
            easyMDE.value('');
            labels = [];
            persist('title', '');
            persist('author', '');
            persist('published', 'false');
            persist('body', '');
            persist('labels', '[]');
            renderLabels();
            updatePreview();
        });

        renderLabels();
        updatePreview();
    });
</script>
