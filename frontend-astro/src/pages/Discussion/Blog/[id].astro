---
import Base from '../../../layouts/Base.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Page from '../../../components/Page.astro';
import MainPageContent from '../../../components/MainPageContent.astro';
import SideBar from '../../../components/SideBar.astro';
import { getAllBlogIds, getBlogData } from '../../../lib/blogs';
import { renderMarkdown } from '../../../lib/markdown';

export async function getStaticPaths() {
    const paths = await getAllBlogIds();
    return paths.map((entry: any) => ({
        params: { id: entry.params.id },
    }));
}

const { id } = Astro.params;
const { blog } = await getBlogData(id!);
const htmlContent = blog.data ? await renderMarkdown(blog.data) : '';
---

<Base title={`${blog.title || 'Blog'} - Open English Translation`}>
    <Header />
    <main style={{ minHeight: '85vh', display: 'flex', flexDirection: 'column', alignItems: 'center' }}>
        <Page>
            <MainPageContent>
                {blog.isEmpty ? (
                    <p>{blog.error}</p>
                ) : (
                    <>
                        <h1>{blog.title}</h1>
                        <div set:html={htmlContent} />
                        <span>{blog.author}</span>
                        <ul>
                            {blog.labels && blog.labels.map((label: string) => (
                                <li>{label}</li>
                            ))}
                        </ul>
                        <span>created on {blog.created}</span>
                        <br />
                        <span>last edited on {blog.last_modified}</span>
                    </>
                )}
            </MainPageContent>
            <SideBar />
        </Page>
    </main>
    <Footer />
</Base>
