---
import WhiteLogo from './WhiteLogo.astro';
---

<div class="footer">
    <div class="footer-inner">
        <div class="grid-cols">
            <div class="column">
                <a href="/">
                    <WhiteLogo class="logo" />
                </a>
                <p class="description">
                    A new, exciting, radical, freely-licensed Bible translation.
                </p>
                <div class="social-links">
                    <a href="https://x.com/OETBible" target="_blank">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            class="icon"
                            ><path
                                d="M14.234 10.162 22.977 0h-2.072l-7.591 8.824L7.251 0H.258l9.168 13.343L.258 24H2.33l8.016-9.318L16.749 24h6.993zm-2.837 3.299-.929-1.329L3.076 1.56h3.182l5.965 8.532.929 1.329 7.754 11.09h-3.182z"
                            ></path></svg
                        >
                    </a>
                    <a href="https://oetbible.substack.com/" target="_blank">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            class="icon"
                            ><path
                                d="M0 0h448v62.804H0V0zm0 229.083h448v282.388L223.954 385.808 0 511.471V229.083zm0-114.542h448v62.804H0v-62.804z"
                            ></path></svg
                        >
                    </a>
                    <a href="/" target="_blank">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            class="icon"
                            ><path
                                d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 0 1 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036 26.805 26.805 0 0 0-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647Z"
                            ></path></svg
                        >
                    </a>
                </div>
            </div>
            <div class="column">
                <span class="section-heading">Information</span>
                <ul>
                    <li><a href="/Intro/WhoFor">Who is it for?</a></li>
                    <li><a href="/Intro/Overview">Overview</a></li>
                    <li><a href="/Intro/Name">Name</a></li>
                    <li><a href="/Design/SourceTexts">Source texts</a></li>
                    <li><a href="/Discussion/FAQ">FAQs</a></li>
                    <li><a href="/Intro/Stories">Stories</a></li>
                </ul>
            </div>
            <div class="column">
                <span class="section-heading">About</span>
                <ul>
                    <li><a href="/About/OET">About OET</a></li>
                    <li><a href="/About/Status">Current status</a></li>
                    <li>
                        <a href="/About/Freely-Given">About Freely-Given</a>
                    </li>
                    <li><a href="/About/CoreValues">Core values</a></li>
                    <li>
                        <a href="/About/StatementOfFaith">Statement of faith</a>
                    </li>
                    <li><a href="/About/Partners">Our partners</a></li>
                    <li><a href="/About/Contact">Contact us</a></li>
                </ul>
            </div>
            <div class="column">
                <span class="section-heading">Versions</span>
                <ul>
                    <li>
                        <a href="/Design/LiteralVersion">Literal Version</a>
                    </li>
                    <li>
                        <a href="/Design/ReadersVersion">Readers' Version</a>
                    </li>
                    <li>
                        <a href="/Design/ExplorersEdition">Explorers' Edition</a
                        >
                    </li>
                    <li>
                        <a href="/Design/ConventionalEdition"
                            >Conventional Edition</a
                        >
                    </li>
                </ul>
            </div>
        </div>
        <div class="bottom">
            <span class="copyright">
                Website copyright &copy; 2022-2026 &nbsp;
                <a href="https://GitHub.com/Freely-Given-org" target="_blank"
                    >Freely-Given.org</a
                >
            </span>
            <span class="buildnote">(Site last built: 27 Apr 2026)</span>
        </div>
    </div>
</div>

<style>
    .footer {
        background-color: var(--blue-black);
        padding: 0.5rem 0.5rem;
    }

    .footer-inner {
        max-width: 1040px;
        margin-left: auto;
        margin-right: auto;
    }

    .grid-cols {
        display: grid;
        grid-template-columns: auto;
        column-gap: 5rem;
        row-gap: 3.3rem;
        padding-top: 4rem;
        padding-bottom: 3rem;
        justify-content: center;
        text-align: center;
    }

    .column {
        color: #fff;
    }

    .logo {
        height: 3.4rem;
        width: auto;
    }

    .description {
        margin: 0;
        margin-top: 0.3rem;
        font-size: 0.9rem;
        color: #ffffffc9;
        max-width: 13rem;
    }

    .social-links {
        margin-top: 1.4rem;
        margin-bottom: 2rem;
        display: flex;
        flex-direction: row;
        gap: 1rem;
        justify-content: center;
    }

    .icon {
        fill: #fff;
        width: 24px;
    }

    .section-heading {
        text-transform: uppercase;
        font-size: 1rem;
        font-weight: 700;
    }

    .column ul {
        padding-left: 0;
        list-style: none;
        margin: 0;
        margin-top: 0.5rem;
    }

    .column li {
        margin-bottom: 0.4rem;
    }

    .column li a {
        color: #fff;
        text-decoration: none;
        font-size: 1.1rem;
        font-weight: 400;
        transition-duration: 0.3s;
    }

    .column li a:hover {
        text-decoration: underline;
    }

    .bottom {
        display: flex;
        flex-direction: column;
        color: #ffffffc9;
        border-top: solid #ffffff14 1px;
        text-align: center;
        padding: 1.2rem 0.5rem;
    }

    .bottom a {
        color: #ffffffc9;
    }

    .copyright {
        font-size: 0.9rem;
    }

    .buildnote {
        font-size: 0.75rem;
    }

    @media (min-width: 767px) {
        .grid-cols {
            text-align: left;
            grid-template-columns: auto auto auto auto;
        }

        .social-links {
            justify-content: left;
        }
    }
</style>
